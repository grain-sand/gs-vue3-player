{
  "name": "gs-player",
  "version": "1.0.0",
  "scripts": {
    "build": "vite build && yarn run build:dts && yarn run build:merge",
    "build:dts": "vue-tsc --declaration --emitDeclarationOnly --rootDir \"src\" --outDir \"tmp\"",
    "build:merge": "gs-rollup -c",
    "test": "vitest run",
    "test:core-ui": "vitest core-ui"
  },
  "dependencies": {
    "gs-base": "^0.1.20",
    "hls.js": "^1.6.15",
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/browser": "^3",
    "@vue/test-utils": "^2.4.6",
    "gs-rollup": "^1.0.6",
    "rollup-plugin-vue": "^6.0.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.5",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3",
    "vue-tsc": "^3.2.6"
  },
  "license": "MIT",
  "type": "module"
}
