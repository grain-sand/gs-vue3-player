{
	"name": "gs-vue3-player",
	"version": "1.0.9",
	"author": {
		"name": "grain-sand"
	},
	"homepage": "https://github.com/grain-sand/gs-vue3-player",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/grain-sand/gs-vue3-player.git"
	},
	"scripts": {
		"build": "vite build && yarn run build:dts && yarn run build:copy:adapter && yarn run build:merge",
		"build:dts": "vue-tsc --declaration --emitDeclarationOnly --rootDir \"src\" --outDir \"tmp\"",
		"build:copy:adapter": "xcopy adapter tmp /s /e /R /Y /I",
		"build:merge": "gs-rollup -c",
		"git:merge": "git branch -f master dev",
		"test": "vitest run",
		"test:core-ui": "vitest core-ui",
		"test:full-ui": "vitest full-ui"
	},
	"dependencies": {
		"gs-base": "^0.1.20",
		"hls.js": "^1.6.15",
		"vue": "^3.5.32"
	},
	"devDependencies": {
		"@types/node": "^25.6.0",
		"@vitejs/plugin-vue": "^6.0.5",
		"@vitest/browser": "^3",
		"@vue/language-plugin-pug": "^3.2.6",
		"@vue/test-utils": "^2.4.6",
		"gs-rollup": "D:\\WorkSpace\\grain-sand\\gs-rollup\\dist",
		"rollup-plugin-vue": "^6.0.0",
		"sass": "^1.97.2",
		"typescript": "^6.0.2",
		"vite": "^8.0.5",
		"vite-plugin-dts": "^4.5.4",
		"vite-svg-loader": "^5.1.1",
		"vitest": "^3",
		"vue-tsc": "^3.2.6"
	},
	"license": "MIT",
	"type": "module",
	"keywords": [
		"vue3-player",
		"video-player",
		"web-player",
		"hls",
		"customizable",
		"internationalization",
		"playlist"
	]
}
