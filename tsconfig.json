{
  "compilerOptions": {
	"target": "ESNext",
	"module": "ESNext",
	"lib": [
	  "ESNext",
	  "DOM"
	],
	"moduleResolution": "Bundler",
	"esModuleInterop": true,
	"forceConsistentCasingInFileNames": true,
	"strict": false,
	"skipLibCheck": true,
	"skipDefaultLibCheck": true,
	"ignoreDeprecations": "6.0"
  },
  "include": [
	"src"
  ],
  "exclude": [
	"node_modules",
	"vite.config.ts"
  ],
  "vueCompilerOptions": {
	"target": 3.3
  }
}
